# Lux Safe — the Lux-network branded wallet build.

NEXT_PUBLIC_BRAND_NAME=Lux Safe
NEXT_PUBLIC_BRAND_SHORT_NAME=Safe
NEXT_PUBLIC_BRAND_DOMAIN=safe.lux.network
NEXT_PUBLIC_BRAND_APP_HOST=safe.lux.network
NEXT_PUBLIC_BRAND_APP_URL=https://safe.lux.network
NEXT_PUBLIC_BRAND_EMAIL=support@lux.network
NEXT_PUBLIC_BRAND_HELP_URL=https://docs.lux.network/safe
NEXT_PUBLIC_BRAND_TERMS_URL=https://lux.network/terms
NEXT_PUBLIC_BRAND_PRIVACY_URL=https://lux.network/privacy
NEXT_PUBLIC_BRAND_IMPRINT_URL=https://lux.network/imprint
NEXT_PUBLIC_BRAND_COOKIE_URL=https://lux.network/cookie
NEXT_PUBLIC_BRAND_LICENSES_URL=https://lux.network/licenses
NEXT_PUBLIC_BRAND_LOGO_URL=/brand/active/logo.svg
NEXT_PUBLIC_BRAND_FAVICON_URL=/brand/active/favicon.ico
NEXT_PUBLIC_BRAND_PRIMARY_COLOR=#0F1B2D
NEXT_PUBLIC_BRAND_STATUS_URL=https://status.lux.network
NEXT_PUBLIC_BRAND_DEVELOPER_URL=https://docs.lux.network
NEXT_PUBLIC_BRAND_GATEWAY_URL=https://safe-cgw.lux.network
NEXT_PUBLIC_BRAND_GATEWAY_STAGING_URL=https://safe-cgw.lux.network
# The app resolves the live gateway from GATEWAY_URL_PRODUCTION when
# IS_PRODUCTION is true (see apps/web/src/config/constants.ts). Pin both so the
# Lux CGW is used at build time (fetch-chains) and at runtime, never upstream.
NEXT_PUBLIC_IS_PRODUCTION=true
NEXT_PUBLIC_GATEWAY_URL_PRODUCTION=https://safe-cgw.lux.network
NEXT_PUBLIC_GATEWAY_URL_STAGING=https://safe-cgw.lux.network
# Default the chain selector to Lux (96369) instead of Ethereum.
NEXT_PUBLIC_DEFAULT_MAINNET_CHAIN_ID=96369
NEXT_PUBLIC_DEFAULT_TESTNET_CHAIN_ID=96369
NEXT_PUBLIC_BRAND_DISCORD_URL=https://discord.gg/lux
NEXT_PUBLIC_BRAND_TWITTER_URL=https://twitter.com/luxdefi
NEXT_PUBLIC_BRAND_SUPPORT_CHAT_ALIAS_DOMAIN=anon.lux.network
NEXT_PUBLIC_BRAND_GITHUB_URL=https://github.com/luxfi/safe-wallet
NEXT_PUBLIC_BRAND_APP_STORE_URL=https://apps.apple.com/app/lux-safe
NEXT_PUBLIC_BRAND_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=network.lux.safe
